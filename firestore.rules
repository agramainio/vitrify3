rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function atelierPath(atelierId) {
      return /databases/$(database)/documents/ateliers/$(atelierId);
    }

    function atelierData(atelierId) {
      return get(atelierPath(atelierId)).data;
    }

    function ownsAtelier(atelierId) {
      return signedIn() && atelierData(atelierId).ownerUid == request.auth.uid;
    }

    function ownsAtelierResource() {
      return signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    function isAtelierMember(atelierId) {
      return signedIn()
        && exists(/databases/$(database)/documents/ateliers/$(atelierId)/members/$(request.auth.uid));
    }

    function canAccessAtelier(atelierId) {
      return ownsAtelier(atelierId) || isAtelierMember(atelierId);
    }

    function validAtelierStatus(status) {
      return status in ['active', 'inactive', 'testing'];
    }

    function validAlias(alias) {
      return alias is string
        && alias.matches('^[a-z0-9][a-z0-9-]{0,62}[a-z0-9]$');
    }

    function createsOwnAtelier() {
      return signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.createdByUid == request.auth.uid
        && validAtelierStatus(request.resource.data.status)
        && validAlias(request.resource.data.alias);
    }

    function keepsAtelierOwnership() {
      return request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.createdByUid == resource.data.createdByUid;
    }

    function scopedToAtelier(atelierId) {
      return !('atelierId' in request.resource.data)
        || request.resource.data.atelierId == atelierId;
    }

    function createDoesNotSpoofUser() {
      return !('createdByUid' in request.resource.data)
        || request.resource.data.createdByUid == request.auth.uid;
    }

    function updateDoesNotSpoofUser() {
      return !('createdByUid' in resource.data)
        || request.resource.data.createdByUid == resource.data.createdByUid;
    }

    function validUserProfile(userId) {
      return request.resource.data.uid == userId
        && (!('email' in request.resource.data) || request.resource.data.email is string || request.resource.data.email == null)
        && (!('displayName' in request.resource.data) || request.resource.data.displayName is string || request.resource.data.displayName == null)
        && (!('activeAtelierId' in request.resource.data) || request.resource.data.activeAtelierId is string)
        && request.resource.data.status in ['active', 'temporary', 'inactive'];
    }

    match /users/{userId} {
      allow create: if signedIn()
        && userId == request.auth.uid
        && validUserProfile(userId);
      allow read: if signedIn() && userId == request.auth.uid;
      allow update: if signedIn()
        && userId == request.auth.uid
        && resource.data.uid == request.auth.uid
        && validUserProfile(userId);
      allow delete: if false;
    }

    match /ateliers/{atelierId} {
      allow create: if createsOwnAtelier();
      allow read: if ownsAtelierResource() || isAtelierMember(atelierId);
      allow update: if signedIn()
        && resource.data.ownerUid == request.auth.uid
        && keepsAtelierOwnership()
        && validAtelierStatus(request.resource.data.status);
      allow delete: if false;

      match /members/{memberId} {
        allow read: if signedIn()
          && (resource.data.uid == request.auth.uid || ownsAtelier(atelierId));
        allow create: if ownsAtelier(atelierId)
          && request.resource.data.uid == memberId
          && request.resource.data.role in ['owner', 'admin', 'staff', 'assistant', 'read-only']
          && request.resource.data.status in ['active', 'temporary', 'inactive'];
        allow update: if ownsAtelier(atelierId)
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.role in ['owner', 'admin', 'staff', 'assistant', 'read-only']
          && request.resource.data.status in ['active', 'temporary', 'inactive'];
        allow delete: if ownsAtelier(atelierId);
      }

      match /{collectionName}/{documentId} {
        allow read: if canAccessAtelier(atelierId);
        allow create: if canAccessAtelier(atelierId)
          && scopedToAtelier(atelierId)
          && createDoesNotSpoofUser();
        allow update: if canAccessAtelier(atelierId)
          && scopedToAtelier(atelierId)
          && updateDoesNotSpoofUser();
        allow delete: if canAccessAtelier(atelierId);
      }
    }

    match /atelierAliases/{alias} {
      allow read: if signedIn();
      allow create: if signedIn()
        && !exists(/databases/$(database)/documents/atelierAliases/$(alias))
        && request.resource.data.alias == alias
        && validAlias(alias)
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.atelierId is string;
      allow update, delete: if false;
    }

    match /{path=**}/members/{memberId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
